<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/katex/katex.min.css">
    <script src="/katex/katex.min.js"></script>
    <script src="/katex/contrib/auto-render.min.js"></script>
    <script>
        window.MathJax = {
            tex: {
                inlineMath: [['$', '$'], ['\\(', '\\)']]
            }
        };
    </script>
    <script id="MathJax-script" async src="/mathjax/tex-mml-chtml.js"></script>
    <title>Submission Confirmed</title>
    <link rel="stylesheet" href="/public/css/tailwind.output.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="font-sans bg-slate-950 text-slate-200 p-6 md:p-12 max-w-4xl mx-auto bg-gradient-to-br from-slate-950 via-slate-900 to-slate-900 min-h-screen">
    <div class="flex flex-col items-center justify-center mb-8 border-b border-slate-800 pb-6">
        <img class="h-16 w-auto object-contain filter drop-shadow-lg mb-4" src="../public/assets/Indian_Institute_of_Information_Technology,_Bhagalpur_logo.png" alt="IIIT Bhagalpur">
        <h2 class="text-base font-bold text-white text-center">Indian Institute of Information Technology Bhagalpur</h2>
        <p class="text-xs text-slate-400 font-semibold uppercase tracking-wider mt-0.5">Response Submission Confirmed</p>
    </div>

    <div class="mb-8 p-6 bg-green-950/40 border border-green-900/60 rounded-2xl text-center shadow-lg backdrop-blur-md">
        <div class="w-12 h-12 rounded-full bg-green-600/10 border border-green-600/20 flex items-center justify-center mx-auto mb-3">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
        </div>
        <h3 class="text-lg font-bold text-white mb-1">Submission Confirmed</h3>
        <p class="text-sm text-slate-300">Your exam responses have been successfully submitted and locked in the server.</p>
    </div>

    <div class="flex justify-center mb-8">
        <button id="downloadExcelBtn" class="px-6 py-3 bg-white text-slate-950 hover:bg-slate-100 active:scale-95 text-sm font-semibold rounded-lg tracking-wide shadow-lg shadow-black/20 cursor-pointer transition duration-150">Download Excel Response</button>
    </div>

    <div class="bg-slate-900/40 border border-slate-800/80 rounded-2xl p-6 mb-8 backdrop-blur-xl shadow-xl" id="userDetail">
        <!-- Will be populated by JS -->
    </div>

    <div class="questionShow" id="questionshow" style="display:none;">
        <!-- Loaded answers summary -->
    </div>

    <div class="space-y-6" id="quizdisplay">
        <!-- Loaded questions and answers list -->
    </div>
    
    <script src="../public/js/UserSubmitForm.js"></script>
</body>
</html>