<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="../public/css/question.css">
    <link rel="stylesheet" href="/katex/katex.min.css">
    <script src="/katex/katex.min.js"></script>
    <script src="/katex/contrib/auto-render.min.js"></script>
    <script>
        window.MathJax = {
            tex: {
                inlineMath: [['$', '$'], ['\\(', '\\)']]
            }
        };
    </script>
    <script id="MathJax-script" async src="/mathjax/tex-mml-chtml.js"></script>
    <title>Admin Panel</title>
</head>

<body>
    <!-- ===== Top Header ===== -->
    <div class="header">
        <div class="heading">
            <h1>Admin Panel &mdash; Exam Portal</h1>
        </div>
        <div class="header-actions">
            <a href="/participants" class="btn-nav">Participants</a>
            <a href="#" class="btn-logout" onclick="localStorage.removeItem('admintoken'); window.location.reload()">Logout</a>
        </div>
    </div>

    <!-- ===== Main Scrollable Dashboard Layout ===== -->
    <div class="dashboard-container">
        
        <!-- Left Sidebar: Controls -->
        <div class="sidebar">
            
            <!-- Timing Form -->
            <div class="sidebar-section">
                <div class="sidebar-section-header">
                    <h3>Exam Schedule</h3>
                    <p>Set timing for Online Examination</p>
                </div>
                <form id="timingConfigForm">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="startTimeInput">Start Time</label>
                            <input type="datetime-local" id="startTimeInput" name="startTime" class="form-control" required>
                        </div>
                        <div class="form-group">
                            <label for="endTimeInput">End Time</label>
                            <input type="datetime-local" id="endTimeInput" name="endTime" class="form-control" required>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary">Save Timing</button>
                </form>
                <div id="timingSuccessMsg" class="success-msg">Timing saved successfully.</div>
            </div>

            <!-- Excel Upload Form -->
            <div class="sidebar-section">
                <div class="sidebar-section-header">
                    <h3>Bulk Import Questions</h3>
                    <p>Upload questions from Excel or CSV sheet</p>
                </div>
                <form id="excelUploadForm" action="/question/uploadexcel" method="post" enctype="multipart/form-data">
                    <div class="form-group">
                        <label for="excelStream">Stream</label>
                        <select name="stream" id="excelStream" class="form-control" required>
                            <option value="">-- select --</option>
                            <option value="<%- CSEvalue %>"><%- CSEvalue %></option>
                            <option value="<%- ECEvalue %>"><%- ECEvalue %></option>
                            <option value="<%- MEAvalue %>"><%- MEAvalue %></option>
                            <option value="<%- Mathvalue %>"><%- Mathvalue %></option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="excelProgram">Program</label>
                        <select name="program" id="excelProgram" class="form-control" required>
                            <option value="MTech">MTech</option>
                            <option value="PhD">PhD</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="excelFile">File (.xlsx, .xls, .csv)</label>
                        <input type="file" id="excelFile" name="excelFile" accept=".xlsx, .xls, .csv" class="form-control" required>
                    </div>
                    <button type="submit" class="btn btn-secondary">Upload Questions</button>
                </form>
                <div id="excelSuccessMsg" class="success-msg"></div>
            </div>

            <!-- Candidates Excel Upload Form -->
            <div class="sidebar-section">
                <div class="sidebar-section-header">
                    <h3>Bulk Import Candidates</h3>
                    <p>Upload candidate logins from Excel sheet</p>
                </div>
                <form id="candidatesUploadForm" action="/user/uploadCandidates" method="post" enctype="multipart/form-data">
                    <div class="form-group">
                        <label for="candidatesFile">File (.xlsx, .xls, .csv)</label>
                        <input type="file" id="candidatesFile" name="candidatesFile" accept=".xlsx, .xls, .csv" class="form-control" required>
                    </div>
                    <button type="submit" class="btn btn-secondary">Upload Candidates</button>
                </form>
                <div id="candidatesSuccessMsg" class="success-msg"></div>
            </div>

            <!-- Manual Add Form -->
            <div class="sidebar-section">
                <div class="sidebar-section-header">
                    <h3>Add Question</h3>
                    <p>Manually insert a single question</p>
                </div>
                <form action="/question/addquestion" id="question_txt" method="post" encType='multipart/form-data'>
                    <div class="form-group">
                        <label for="stream">Stream</label>
                        <select name="stream" id="stream" class="form-control" required>
                            <option value="">-- select --</option>
                            <option value="<%- CSEvalue %>"><%- CSEvalue %></option>
                            <option value="<%- ECEvalue %>"><%- ECEvalue %></option>
                            <option value="<%- MEAvalue %>"><%- MEAvalue %></option>
                            <option value="<%- Mathvalue %>"><%- Mathvalue %></option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="manualProgram">Program</label>
                        <select name="program" id="manualProgram" class="form-control" required>
                            <option value="MTech">MTech</option>
                            <option value="PhD">PhD</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="ques">Question Text</label>
                        <input type="text" name="ques" placeholder="Question statement" id="ques" class="form-control">
                    </div>

                    <div class="form-group">
                        <label for="image">Image (optional)</label>
                        <input type="file" name="img" id="image" class="form-control">
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="option1">Option A</label>
                            <input type="text" name="option1" placeholder="Option A" id="option1" class="form-control" required>
                        </div>
                        <div class="form-group">
                            <label for="option2">Option B</label>
                            <input type="text" name="option2" placeholder="Option B" id="option2" class="form-control" required>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="option3">Option C</label>
                            <input type="text" name="option3" placeholder="Option C" id="option3" class="form-control" required>
                        </div>
                        <div class="form-group">
                            <label for="option4">Option D</label>
                            <input type="text" name="option4" placeholder="Option D" id="option4" class="form-control" required>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="answer">Answer Key</label>
                        <select name="answer" id="answer" class="form-control" required>
                            <option value="">-- select --</option>
                            <option value="option1">A</option>
                            <option value="option2">B</option>
                            <option value="option3">C</option>
                            <option value="option4">D</option>
                        </select>
                    </div>

                    <button type="submit" id="add_question" class="btn btn-primary">Add Question</button>
                </form>
            </div>

        </div>

        <!-- Right Pane: Questions List -->
        <div class="main-content">
            <div class="stream-filter">
                <label for="browseStream">Filter Questions</label>
                <div style="display: flex; gap: 12px; align-items: center;">
                    <select id="browseStream" onchange="selectStream(this.value)" required>
                        <option value="<%- CSEvalue %>"><%- CSEvalue %></option>
                        <option value="<%- ECEvalue %>"><%- ECEvalue %></option>
                        <option value="<%- MEAvalue %>"><%- MEAvalue %></option>
                        <option value="<%- Mathvalue %>"><%- Mathvalue %></option>
                    </select>
                    <select id="browseProgram" onchange="selectProgram(this.value)" required style="width: 120px; padding: 8px 12px; border: 1px solid #ccc; border-radius: 6px; font-size: 14px; outline: none; font-family: 'Inter', sans-serif;">
                        <option value="MTech">MTech</option>
                        <option value="PhD">PhD</option>
                    </select>
                </div>
            </div>
            
            <div class="questionShow" id="questionshow" style="display:none;"></div>
            
            <div class="quiz-list" id="quizdisplay">
                <!-- Loaded quiz questions will be populated here -->
            </div>
        </div>

    </div>

    <script>
        let CSEvalue = `<%- CSEvalue %>`
        let ECEvalue = `<%- ECEvalue %>`
        let MEAvalue = `<%- MEAvalue %>`
        let Mathvalue = `<%- Mathvalue %>`
    </script>
    <script src="../public/js/question.js"></script>
</body>

</html>
