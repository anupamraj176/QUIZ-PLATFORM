<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/public/css/tailwind.output.css">
    <link rel="stylesheet" href="/katex/katex.min.css">
    <script src="/katex/katex.min.js"></script>
    <script src="/katex/contrib/auto-render.min.js"></script>
    <script>
        window.MathJax = {
            tex: {
                inlineMath: [['$', '$'], ['\\(', '\\)']]
            }
        };
    </script>
    <script id="MathJax-script" async src="/mathjax/tex-mml-chtml.js"></script>
    <title>Exam Portal</title>
</head>

<body class="font-sans bg-slate-950 text-slate-200 min-h-screen flex flex-col bg-gradient-to-br from-slate-950 via-slate-900 to-slate-900 selection:bg-slate-800 selection:text-white">
    <!-- Sticky Top Header -->
    <div class="bg-slate-900/80 border-b border-slate-800/80 py-4 px-6 flex flex-col sm:flex-row items-center justify-between sticky top-0 z-50 backdrop-blur-md gap-4">
        <div class="detail flex flex-wrap items-center gap-x-6 gap-y-1 text-sm text-slate-300 font-medium" id="Detail">
            <!-- Candidate details injected from JS -->
        </div>
        <div class="timer bg-slate-950/60 border border-slate-800/80 rounded-xl px-5 py-2.5 flex items-center gap-3 text-center backdrop-blur-sm">
            <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Time Remaining:</span>
            <%- include ('./timer.ejs') %> 
        </div>
    </div>

    <!-- Main Content Container -->
    <div class="w-full max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-8 p-6 flex-grow">
        <!-- Left Side: MCQ Question Panel -->
        <div class="lg:col-span-8 bg-slate-900/30 border border-slate-800 rounded-2xl p-6 md:p-8 shadow-xl backdrop-blur-xl flex flex-col min-h-[500px]" id="quizdisplay">
            <!-- Questions injected from JS -->
        </div>

        <!-- Right Side: Navigation Panel -->
        <div class="lg:col-span-4 bg-slate-900/30 border border-slate-800 rounded-2xl p-6 shadow-xl backdrop-blur-xl flex flex-col h-fit gap-6">
            <div>
                <h2 class="text-sm font-bold text-white uppercase tracking-wider mb-4 border-b border-slate-800 pb-2">Questions Navigation</h2>
                <div class="grid grid-cols-5 gap-3 max-h-[250px] overflow-y-auto pr-1" id="questionshow">
                    <!-- Question navigation bubbles injected from JS -->
                </div>
            </div>
            
            <!-- Legend Indicators -->
            <div class="border-t border-slate-800 pt-5 space-y-3">
                <h3 class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Status Legend</h3>
                <div class="grid grid-cols-2 gap-x-4 gap-y-2 text-xs">
                    <div class="flex items-center gap-2.5">
                        <div class="w-3.5 h-3.5 rounded bg-purple-600 shadow-md shadow-purple-900/10"></div>
                        <span class="text-slate-300 font-medium">Marked for Review</span>
                    </div>
                    <div class="flex items-center gap-2.5">
                        <div class="w-3.5 h-3.5 rounded bg-red-650 shadow-md shadow-red-950/10"></div>
                        <span class="text-slate-300 font-medium">Not Answered</span>
                    </div>
                    <div class="flex items-center gap-2.5">
                        <div class="w-3.5 h-3.5 rounded bg-green-600 shadow-md shadow-green-900/10"></div>
                        <span class="text-slate-300 font-medium">Answered</span>
                    </div>
                    <div class="flex items-center gap-2.5">
                        <div class="w-3.5 h-3.5 rounded bg-slate-800 border border-slate-700/50"></div>
                        <span class="text-slate-300 font-medium">Not Visited</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <footer class="py-4 text-center text-xs text-slate-500 border-t border-slate-900/50 mt-auto bg-slate-950/40">
        © 2026 Indian Institute of Information Technology Bhagalpur. All rights reserved.
    </footer>
    
    <!-- Beautiful Custom Success Overlay Modal -->
    <div id="successModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.7); backdrop-filter: blur(8px); z-index: 10000; justify-content: center; align-items: center;">
        <div style="background: #0f172a; border: 1px solid #1e293b; width: 90%; max-width: 450px; padding: 40px 30px; border-radius: 16px; text-align: center; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5); font-family: 'Inter', sans-serif; animation: modalSlideIn 0.3s ease-out;">
            <div style="width: 72px; height: 72px; background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 24px;">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
            </div>
            <h2 style="font-size: 20px; font-weight: 700; color: #ffffff; margin-bottom: 12px; tracking-tight">Exam Submitted!</h2>
            <p style="font-size: 14px; color: #94a3b8; line-height: 1.6; margin-bottom: 28px;">Your responses have been successfully recorded. Thank you for taking the examination.</p>
            <button onclick="logout()" style="background: #ffffff; color: #0f172a; border: none; padding: 12px 30px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; transition: background 0.15s; width: 100%; outline: none; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.3);">
                Close and Exit
            </button>
        </div>
    </div>
    
    <style>
        @keyframes modalSlideIn {
            from { transform: translateY(30px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }
    </style>

    <script src="../public/js/quiz.js"></script>
</body>
</html>