<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Candidate Login</title>
    <link rel="stylesheet" href="/public/css/tailwind.output.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>

<body class="font-sans bg-slate-950 text-slate-100 flex items-center justify-center min-h-screen p-4 bg-gradient-to-br from-slate-950 via-slate-900 to-slate-900">
    <div class="w-full max-w-md p-8 rounded-2xl bg-slate-900/50 border border-slate-800 backdrop-blur-xl shadow-2xl transition-all duration-300 hover:border-slate-700/80">
        <div class="flex justify-center mb-6">
            <img class="h-20 w-auto object-contain filter drop-shadow-lg" src="../public/assets/Indian_Institute_of_Information_Technology,_Bhagalpur_logo.png" alt="IIIT Bhagalpur">
        </div>
        <div class="text-center mb-8">
            <h3 class="text-lg font-bold leading-snug tracking-tight text-white">Indian Institute of Information Technology Bhagalpur</h3>
            <p class="text-xs text-slate-400 mt-1 font-medium tracking-wide uppercase">Candidate Login Portal</p>
        </div>
        
        <div id="warning" class="mb-5 p-3.5 bg-red-950/40 border border-red-900/60 rounded-lg text-red-400 text-sm font-medium text-center shadow-inner" style="display: none;"></div>

        <form action="/user/login" id="loginsubmit" method="post" class="space-y-5">
            <div>
                <label for="applicationNo" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider mb-2">Application No</label>
                <input id="applicationNo" type="text" name="applicationNo" class="w-full px-4 py-3 bg-slate-950/60 border border-slate-800 rounded-lg text-sm text-slate-100 placeholder-slate-500 focus:outline-none focus:border-slate-600 focus:ring-1 focus:ring-slate-600 transition duration-150" placeholder="Enter application number" required>
            </div>
            <div>
                <label for="password" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider mb-2">Password</label>
                <input type="password" id="password" name="password" class="w-full px-4 py-3 bg-slate-950/60 border border-slate-800 rounded-lg text-sm text-slate-100 placeholder-slate-500 focus:outline-none focus:border-slate-600 focus:ring-1 focus:ring-slate-600 transition duration-150" placeholder="Enter password" required>
            </div>
            <input type="submit" value="Login" class="w-full py-3 bg-white text-slate-950 hover:bg-slate-100 active:scale-[0.98] rounded-lg text-sm font-semibold tracking-wide cursor-pointer transition-all duration-150 shadow-lg shadow-black/20 mt-6">
        </form>
    </div>

    <script>
        if (localStorage.getItem('token')) {
            window.location.href = '/data'
        }
        document.getElementById('loginsubmit').addEventListener('submit', (e) => {
            e.preventDefault();
            const warningDiv = document.getElementById('warning');
            warningDiv.style.display = 'none';

            fetch(e.target.action, {
                method: "POST",
                body: new URLSearchParams(new FormData(e.target)),
            })
                .then((res) => res.json())
                .then((body) => {
                    if (body.status === 0) {
                        localStorage.setItem('token', `${body.authtoken}`)
                        if (body.stream && body.stream.length > 0) {
                            window.location.href = '/instruction'
                        } else {
                            window.location.href = '/data'
                        }
                    } else if (body.status === 2){
                        warningDiv.innerHTML = "Already submitted / logged in";
                        warningDiv.style.display = 'block';
                    } else {
                        warningDiv.innerHTML = "Invalid Credentials";
                        warningDiv.style.display = 'block';
                    }
                })
                .catch((error) => {
                    warningDiv.innerHTML = "Network error logging in";
                    warningDiv.style.display = 'block';
                });
        })
    </script>
</body>

</html>