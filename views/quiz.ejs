<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="../public/css/quiz.css">
    <link rel="stylesheet" href="/katex/katex.min.css">
    <script src="/katex/katex.min.js"></script>
    <script src="/katex/contrib/auto-render.min.js"></script>
    <script>
        window.MathJax = {
            tex: {
                inlineMath: [['$', '$'], ['\\(', '\\)']]
            }
        };
    </script>
    <script id="MathJax-script" async src="/mathjax/tex-mml-chtml.js"></script>
    <title>QUIZ</title>
</head>

<body>
    <div class="header">
        <div class="detail" id="Detail">
        </div>
        <div class="timer">
            Time left to finish
            <%- include ('./timer.ejs') %> 
            <!-- <a href="/instruction">
                <button type="button">Instruction</button>
            </a> -->
        </div>
    </div>
    <div class="main">
        <div class="quiz" id="quizdisplay">
            
        </div>
        <div class="question">
            <h1>Navigate to any question</h1>
            <div class="questionShow" id="questionshow">
                
            </div>
            <!-- <div>
                <button type="button" onclick="logout()">Finish</button>
            </div> -->
            <div>

                <div class="showinfo">
                    <div class="circlequiz" style="background-color: purple;"></div>
                    <p>Mark as review</p>
                </div>
                
                <div class="showinfo">
                    <div class="circlequiz" style="background-color: red;"></div>
                    <p>Not answered</p>
                </div>
                
                <div class="showinfo">
                    <div class="circlequiz" style="background-color: green;"></div>
                    <p>Answered</p>
                </div>
                
                <div class="showinfo">
                    <div class="circlequiz" style="background-color: gray;"></div>
                    <p>Not Visited</p>
                </div>
            </div>
        </div>
    </div>
    <footer></footer>
    
    <!-- Beautiful Custom Success Overlay Modal -->
    <div id="successModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.7); backdrop-filter: blur(8px); z-index: 10000; justify-content: center; align-items: center;">
        <div style="background: #ffffff; width: 90%; max-width: 450px; padding: 40px 30px; border-radius: 12px; text-align: center; box-shadow: 0 20px 40px rgba(0,0,0,0.3); font-family: 'Inter', sans-serif; animation: modalSlideIn 0.3s ease-out;">
            <div style="width: 72px; height: 72px; background: #e8f5e9; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 24px;">
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#2e7d32" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
            </div>
            <h2 style="font-size: 24px; font-weight: 700; color: #111111; margin-bottom: 12px;">Exam Submitted!</h2>
            <p style="font-size: 15px; color: #555555; line-height: 1.6; margin-bottom: 28px;">Your responses have been successfully recorded. Thank you for taking the examination.</p>
            <button onclick="logout()" style="background: #111111; color: #ffffff; border: none; padding: 12px 30px; border-radius: 6px; font-size: 15px; font-weight: 600; cursor: pointer; transition: background 0.15s; width: 100%; outline: none;">
                Close and Exit
            </button>
        </div>
    </div>
    
    <style>
        @keyframes modalSlideIn {
            from { transform: translateY(30px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }
    </style>

    <script src="../public/js/quiz.js"></script>
</body>
</html>