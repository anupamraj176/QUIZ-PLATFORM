<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin &mdash; Candidate Database</title>
    <link rel="stylesheet" href="../public/css/participant.css">
</head>
<body>
    <!-- ===== Top Navbar ===== -->
    <div class="header-nav">
        <h1>Candidate Database</h1>
        <div class="header-nav-actions">
            <button onclick="generateResult()" class="btn-nav-action btn-result-action">Download Excel Results</button>
            <a href="/addquiz" class="btn-nav-action">Back to Questions</a>
        </div>
    </div>

    <!-- ===== Main Scrollable Area ===== -->
    <div class="container">
        <!-- Stream Filter Bar -->
        <div class="filter-bar">
            <span>Filter Stream:</span>
            <button class="btn-filter" onclick="changestream('<%- CSEvalue %>')"><%- CSEvalue %></button>
            <button class="btn-filter" onclick="changestream('<%- ECEvalue %>')"><%- ECEvalue %></button>
            <button class="btn-filter" onclick="changestream('<%- MEAvalue %>')"><%- MEAvalue %></button>
            <button class="btn-filter" onclick="changestream('<%- Mathvalue %>')"><%- Mathvalue %></button>
        </div>

        <!-- Participants Table Grid -->
        <div id="participantsDatadesign">
            <table>
                <thead>
                    <tr>
                        <th>S.No.</th>
                        <th>Application No.</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Stream</th>
                        <th>Marks</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="participantsTableBody">
                    <!-- Populated dynamically via JS -->
                </tbody>
            </table>
        </div>
    </div>

    <script>
        let CSEvalue = `<%- CSEvalue %>`
        let ECEvalue = `<%- ECEvalue %>`
        let MEAvalue = `<%- MEAvalue %>`
        let Mathvalue = `<%- Mathvalue %>`
    </script>
    <script src="../public/js/participant.js"></script>
</body>
</html>
