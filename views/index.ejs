<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Candidate Login</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background-color: #ffffff;
            color: #111111;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        .login-container {
            width: 100%;
            max-width: 400px;
            padding: 32px 24px;
            border: 1px solid #eaeaea;
            border-radius: 6px;
            background: #fafafa;
        }

        .logo {
            display: flex;
            justify-content: center;
            margin-bottom: 16px;
        }

        .logo img {
            height: 80px;
            width: auto;
        }

        .about {
            text-align: center;
            margin-bottom: 24px;
        }

        .about h3 {
            font-size: 15px; /* Increased */
            font-weight: 600;
            color: #111111;
            line-height: 1.5;
        }

        .form-group {
            margin-bottom: 16px;
        }

        .form-group label {
            display: block;
            font-size: 13px; /* Increased */
            font-weight: 600;
            color: #555555;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 6px;
        }

        .form-control {
            width: 100%;
            padding: 10px 12px;
            border: 1px solid #cccccc;
            border-radius: 4px;
            font-size: 15px; /* Increased */
            font-family: 'Inter', sans-serif;
            color: #111111;
            background: #ffffff;
            outline: none;
            transition: border-color 0.15s;
        }

        .form-control:focus {
            border-color: #111111;
        }

        .btn {
            width: 100%;
            padding: 10px;
            background: #111111;
            color: #ffffff;
            border: 1px solid #111111;
            border-radius: 4px;
            font-size: 15px; /* Increased */
            font-weight: 600;
            cursor: pointer;
            transition: background 0.15s;
            margin-top: 8px;
        }

        .btn:hover {
            background: #333333;
        }

        #warning {
            margin-bottom: 14px;
            padding: 8px 12px;
            background: #ffebee;
            border: 1px solid #ffcccc;
            border-radius: 4px;
            color: #c62828;
            font-size: 14px; /* Increased */
            font-weight: 500;
            text-align: center;
        }
    </style>
</head>

<body>
    <div class="login-container">
        <div class="logo">
            <img src="../public/assets/Indian_Institute_of_Information_Technology,_Bhagalpur_logo.png" alt="IIIT Bhagalpur">
        </div>
        <div class="about">
            <h3>Indian Institute of Information Technology Bhagalpur</h3>
        </div>
        
        <div id="warning" style="display: none;"></div>

        <form action="/user/login" id="loginsubmit" method="post">
            <div class="form-group">
                <label for="applicationNo">Application No</label>
                <input id="applicationNo" type="text" name="applicationNo" class="form-control" placeholder="Enter application number" required>
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" class="form-control" placeholder="Enter password" required>
            </div>
            <input type="submit" value="Login" class="btn">
        </form>
    </div>

    <script>
        if (localStorage.getItem('token')) {
            window.location.href = '/data'
        }
        document.getElementById('loginsubmit').addEventListener('submit', (e) => {
            e.preventDefault();
            const warningDiv = document.getElementById('warning');
            warningDiv.style.display = 'none';

            fetch(e.target.action, {
                method: "POST",
                body: new URLSearchParams(new FormData(e.target)),
            })
                .then((res) => res.json())
                .then((body) => {
                    if (body.status === 0) {
                        localStorage.setItem('token', `${body.authtoken}`)
                        if (body.stream && body.stream.length > 0) {
                            window.location.href = '/instruction'
                        } else {
                            window.location.href = '/data'
                        }
                    } else if (body.status === 2){
                        warningDiv.innerHTML = "Already submitted / logged in";
                        warningDiv.style.display = 'block';
                    } else {
                        warningDiv.innerHTML = "Invalid Credentials";
                        warningDiv.style.display = 'block';
                    }
                })
                .catch((error) => {
                    warningDiv.innerHTML = "Network error logging in";
                    warningDiv.style.display = 'block';
                });
        })
    </script>
</body>

</html>