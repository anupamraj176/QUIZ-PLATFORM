<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Candidate Details</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background-color: #ffffff;
            color: #111111;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        .details-container {
            width: 100%;
            max-width: 450px;
            padding: 32px 24px;
            border: 1px solid #eaeaea;
            border-radius: 6px;
            background: #fafafa;
        }

        .logo {
            display: flex;
            justify-content: center;
            margin-bottom: 16px;
        }

        .logo img {
            height: 72px;
            width: auto;
        }

        .about {
            text-align: center;
            margin-bottom: 24px;
        }

        .about h3 {
            font-size: 15px; /* Increased */
            font-weight: 600;
            color: #111111;
            line-height: 1.5;
        }

        .form-title {
            font-size: 17px; /* Increased */
            font-weight: 600;
            margin-bottom: 20px;
            text-align: center;
            color: #111111;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .form-group {
            margin-bottom: 16px;
        }

        .form-group label {
            display: block;
            font-size: 13px; /* Increased */
            font-weight: 600;
            color: #555555;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 6px;
        }

        .form-control {
            width: 100%;
            padding: 10px 12px;
            border: 1px solid #cccccc;
            border-radius: 4px;
            font-size: 15px; /* Increased */
            font-family: 'Inter', sans-serif;
            color: #111111;
            background: #ffffff;
            outline: none;
            transition: border-color 0.15s;
        }

        .form-control:focus {
            border-color: #111111;
        }

        .btn {
            width: 100%;
            padding: 10px;
            background: #111111;
            color: #ffffff;
            border: 1px solid #111111;
            border-radius: 4px;
            font-size: 15px; /* Increased */
            font-weight: 600;
            cursor: pointer;
            transition: background 0.15s;
            margin-top: 8px;
        }

        .btn:hover {
            background: #333333;
        }

        #warning {
            margin-bottom: 14px;
            padding: 8px 12px;
            background: #ffebee;
            border: 1px solid #ffcccc;
            border-radius: 4px;
            color: #c62828;
            font-size: 14px; /* Increased */
            font-weight: 500;
            text-align: center;
        }
    </style>
</head>

<body>
    <div class="details-container">
        <div class="logo">
            <img src="../public/assets/Indian_Institute_of_Information_Technology,_Bhagalpur_logo.png" alt="IIIT Bhagalpur">
        </div>
        <div class="about">
            <h3>Indian Institute of Information Technology Bhagalpur</h3>
        </div>

        <div class="form-title">Candidate Details Form</div>
        <div id="warning" style="display: none;"></div>

        <form action="/user/adddata" id="loginsubmit" method="post">
            <div class="form-group">
                <label for="name">Full Name</label>
                <input id="name" type="text" name="name" class="form-control" placeholder="Enter your full name" required>
            </div>
            <div class="form-group">
                <label for="program">Category of Post</label>
                <select name="program" id="program" class="form-control" required>
                    <option value="">-- select category --</option>
                    <option value="MTech">MTech</option>
                    <option value="PhD">PhD</option>
                </select>
            </div>
            <div class="form-group">
                <label for="stream">Post applied for</label>
                <select name="stream" id="stream" class="form-control" required>
                    <option value="">-- select program/stream --</option>
                </select>
            </div>
            <input type="submit" value="Continue to Exam" class="btn">
        </form>
    </div>

    <script>
        let CSEvalue = `<%- CSEvalue %>`
        let ECEvalue = `<%- ECEvalue %>`
        let MEAvalue = `<%- MEAvalue %>`
        let Mathvalue = `<%- Mathvalue %>`

        if (localStorage.getItem('token')) {
        } else {
            window.location.href = '/'
        }

        document.getElementById("program").addEventListener("change", (e) => {
            const streamSelect = document.getElementById('stream');
            if (e.target.value === 'PhD' || e.target.value === 'MTech') {
                streamSelect.innerHTML = `
                    <option value="">-- select program/stream --</option>
                    <option value="${CSEvalue}">${CSEvalue}</option>
                    <option value="${ECEvalue}">${ECEvalue}</option>
                    <option value="${MEAvalue}">${MEAvalue}</option>
                    <option value="${Mathvalue}">${Mathvalue}</option>
                `;
            } else {
                streamSelect.innerHTML = `<option value="">-- select program/stream --</option>`;
            }
        });

        function fetchUser() {
            fetch(`/user/access`, {
                method: 'POST',
                headers: {
                    'content-type': 'application/json',
                    'auth_token': `${localStorage.getItem('token')}`
                }
            })
                .then((res) => res.json())
                .then((body) => {
                    if (body.status === 0) {
                        if (body.data.stream && body.data.stream.length !== 0) {
                            window.location.href = '/instruction'
                        }
                    } else {
                        localStorage.removeItem('token')
                        window.location.href = '/'
                    }
                })
                .catch((error) => {
                    localStorage.removeItem('token')
                    window.location.href = '/'
                });
        }

        fetchUser();

        document.getElementById('loginsubmit').addEventListener('submit', (e) => {
            e.preventDefault();
            const warningDiv = document.getElementById('warning');
            warningDiv.style.display = 'none';

            fetch(e.target.action, {
                method: "POST",
                headers: {
                    'auth_token': `${localStorage.getItem('token')}`
                },
                body: new URLSearchParams(new FormData(e.target)),
            })
                .then((res) => res.json())
                .then((body) => {
                    if (body.status === 0) {
                        window.location.href = '/instruction'
                    } else {
                        warningDiv.innerHTML = "Error saving details. Please try again.";
                        warningDiv.style.display = 'block';
                    }
                })
                .catch((error) => {
                    warningDiv.innerHTML = "Network error saving details";
                    warningDiv.style.display = 'block';
                });
        })
    </script>
</body>

</html>
