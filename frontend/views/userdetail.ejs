<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Candidate Details</title>
    <link rel="stylesheet" href="/public/css/tailwind.output.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>

<body class="font-sans bg-slate-950 text-slate-100 flex items-center justify-center min-h-screen p-4 bg-gradient-to-br from-slate-950 via-slate-900 to-slate-900">
    <div class="w-full max-w-lg p-8 rounded-2xl bg-slate-900/50 border border-slate-800 backdrop-blur-xl shadow-2xl transition-all duration-300 hover:border-slate-700/80">
        <div class="flex justify-center mb-6">
            <img class="h-16 w-auto object-contain filter drop-shadow-lg" src="../public/assets/Indian_Institute_of_Information_Technology,_Bhagalpur_logo.png" alt="IIIT Bhagalpur">
        </div>
        <div class="text-center mb-8 border-b border-slate-800/80 pb-6">
            <h3 class="text-base font-bold leading-snug tracking-tight text-white">Indian Institute of Information Technology Bhagalpur</h3>
            <p class="text-xs text-slate-400 mt-1 font-medium tracking-wide uppercase">Candidate Profile Form</p>
        </div>

        <div class="text-center text-sm font-semibold tracking-wider uppercase text-white mb-6">Candidate Details Form</div>
        <div id="warning" class="mb-5 p-3.5 bg-red-950/40 border border-red-900/60 rounded-lg text-red-400 text-sm font-medium text-center shadow-inner" style="display: none;"></div>

        <form action="/user/adddata" id="loginsubmit" method="post" class="space-y-5">
            <div>
                <label for="name" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider mb-2">Full Name</label>
                <input id="name" type="text" name="name" class="w-full px-4 py-3 bg-slate-950/60 border border-slate-800 rounded-lg text-sm text-slate-100 placeholder-slate-500 focus:outline-none focus:border-slate-600 focus:ring-1 focus:ring-slate-600 transition duration-150" placeholder="Enter your full name" required>
            </div>
            <div>
                <label for="program" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider mb-2">Category of Post</label>
                <select name="program" id="program" class="w-full px-4 py-3 bg-slate-950/60 border border-slate-800 rounded-lg text-sm text-slate-100 focus:outline-none focus:border-slate-600 focus:ring-1 focus:ring-slate-600 transition duration-150" required>
                    <option value="" class="bg-slate-900 text-slate-400">-- select category --</option>
                    <option value="MTech" class="bg-slate-900 text-slate-100">MTech</option>
                    <option value="PhD" class="bg-slate-900 text-slate-100">PhD</option>
                </select>
            </div>
            <div>
                <label for="stream" class="block text-[11px] font-bold text-slate-400 uppercase tracking-wider mb-2">Post applied for</label>
                <select name="stream" id="stream" class="w-full px-4 py-3 bg-slate-950/60 border border-slate-800 rounded-lg text-sm text-slate-100 focus:outline-none focus:border-slate-600 focus:ring-1 focus:ring-slate-600 transition duration-150" required>
                    <option value="" class="bg-slate-900 text-slate-400">-- select program/stream --</option>
                </select>
            </div>
            <input type="submit" value="Continue to Exam" class="w-full py-3 bg-white text-slate-950 hover:bg-slate-100 active:scale-[0.98] rounded-lg text-sm font-semibold tracking-wide cursor-pointer transition-all duration-150 shadow-lg shadow-black/20 mt-6">
        </form>
    </div>

    <script>
        let CSEvalue = `<%- CSEvalue %>`
        let ECEvalue = `<%- ECEvalue %>`
        let MEAvalue = `<%- MEAvalue %>`
        let Mathvalue = `<%- Mathvalue %>`

        if (localStorage.getItem('token')) {
        } else {
            window.location.href = '/'
        }

        document.getElementById("program").addEventListener("change", (e) => {
            const streamSelect = document.getElementById('stream');
            if (e.target.value === 'PhD' || e.target.value === 'MTech') {
                streamSelect.innerHTML = `
                    <option value="">-- select program/stream --</option>
                    <option value="${CSEvalue}">${CSEvalue}</option>
                    <option value="${ECEvalue}">${ECEvalue}</option>
                    <option value="${MEAvalue}">${MEAvalue}</option>
                    <option value="${Mathvalue}">${Mathvalue}</option>
                `;
            } else {
                streamSelect.innerHTML = `<option value="">-- select program/stream --</option>`;
            }
        });

        function fetchUser() {
            fetch(`/user/access`, {
                method: 'POST',
                headers: {
                    'content-type': 'application/json',
                    'auth_token': `${localStorage.getItem('token')}`
                }
            })
                .then((res) => res.json())
                .then((body) => {
                    if (body.status === 0) {
                        if (body.data.stream && body.data.stream.length !== 0) {
                            window.location.href = '/instruction'
                        }
                    } else {
                        localStorage.removeItem('token')
                        window.location.href = '/'
                    }
                })
                .catch((error) => {
                    localStorage.removeItem('token')
                    window.location.href = '/'
                });
        }

        fetchUser();

        document.getElementById('loginsubmit').addEventListener('submit', (e) => {
            e.preventDefault();
            const warningDiv = document.getElementById('warning');
            warningDiv.style.display = 'none';

            fetch(e.target.action, {
                method: "POST",
                headers: {
                    'auth_token': `${localStorage.getItem('token')}`
                },
                body: new URLSearchParams(new FormData(e.target)),
            })
                .then((res) => res.json())
                .then((body) => {
                    if (body.status === 0) {
                        window.location.href = '/instruction'
                    } else {
                        warningDiv.innerHTML = "Error saving details. Please try again.";
                        warningDiv.style.display = 'block';
                    }
                })
                .catch((error) => {
                    warningDiv.innerHTML = "Network error saving details";
                    warningDiv.style.display = 'block';
                });
        })
    </script>
</body>

</html>
